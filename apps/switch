#!/bin/bash -e

echo "$@"

if [[ $# == 0 ]]; then
	echo "missing config name, usage switch <config name> <optional other args>"
	exit 1
fi

config_name="$1"
shift

function build() {
	nix build \
		--extra-experimental-features 'nix-command flakes' \
		--show-trace \
		".#$1"
}

case $(uname -o) in
Darwin)
	build "darwinConfigurations.$config_name.system"

	sudo ./result/sw/bin/darwin-rebuild switch \
		--show-trace \
		--flake ".#$config_name" "$@"
	;;
Linux)
	if [ -f /etc/NIXOS ]; then
		build "nixosConfigurations.$config_name.system"
		sudo nixos-rebuild switch \
			--show-trace \
			--flake ".#$config_name" "$@"
	else
		echo "Need to implement/port over linux"
		exit 1
	fi

	;;
*)
	echo "System type $(uname -o) not supported"
	exit 1
	;;
esac

echo ""
echo "=== Package changes ==="
current=$(readlink /nix/var/nix/profiles/system | grep -o '[0-9]*')
previous=$((current - 1))
nix store diff-closures "/nix/var/nix/profiles/system-${previous}-link" "/nix/var/nix/profiles/system-${current}-link" 2>/dev/null || true

if command -v cachix &>/dev/null; then
	echo ""
	echo "=== Cachix ==="
	echo "pushing to binary cache..."
	cachix push grady-saccullo ./result
fi
